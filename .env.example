# Database
DATABASE_URL=sqlite+aiosqlite:///./biogas.db

# Dashscope (Alibaba Cloud AI)
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus

# MinerU (document parsing)
MINERU_MODEL_SIZE=small

# WeChat
WECHAT_APPID=your-wechat-appid
WECHAT_APPSECRET=your-wechat-appsecret
WECHAT_REDIRECT_URL=http://localhost:8000/api/auth/callback

# Aliyun OSS
ALIYUN_OSS_ACCESS_KEY=your-access-key
ALIYUN_OSS_SECRET_KEY=your-secret-key
ALIYUN_OSS_BUCKET=your-bucket-name
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# Admin
ADMIN_WECHAT_OPENID=your-admin-openid

# App
BASE_URL=http://localhost:8000
